# Copy this file to .env.local and fill in values from your Supabase project
# (Settings -> API in the Supabase dashboard).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Never expose this to the browser or commit it.
# Used for admin actions (creating users) and to run migrations/seed scripts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email notifications via Resend (resend.com -> API Keys). Optional — if unset,
# the app just skips sending email and keeps working with in-app notifications only.
RESEND_API_KEY=
# Until you verify your own sending domain in Resend, you can only send to the
# email address you signed up with — fine for testing, not for real users yet.
RESEND_FROM_EMAIL=ProcurePro <onboarding@resend.dev>

# Used to build links inside notification emails (e.g. http://localhost:3000).
# Set this to your real deployed URL in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Error monitoring via Sentry (sentry.io -> New Project -> Next.js -> Settings -> Client Keys for the DSN).
# Optional — if unset, Sentry.init just no-ops and nothing reports.
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only (source map upload). Create at sentry.io -> Settings -> Auth Tokens, scope org:ci.
SENTRY_AUTH_TOKEN=

# RigSource (rigsource.vercel.app) is the sourcing app this ProcurePro instance
# pairs with. The Users & Departments page uses these to show admins a
# one-click invite link (/register?invite=CODE) to share with a user.
# Optional — if unset, the "Grant RigSource access" section is hidden.
RIGSOURCE_URL=https://rigsource.vercel.app
RIGSOURCE_INVITE_CODE=
